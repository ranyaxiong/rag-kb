# 生产环境配置模板
# 公网部署时使用此配置

# ==== API密钥配置 ====
# 生产环境推荐使用系统环境变量或Docker secrets
JWT_SECRET_FILE=/run/secrets/jwt_secret/token_secret
ADMIN_PASSWORD_HASH_FILE=/run/secrets/admin_password_hash/password_hash
API_KEY_FILE=/run/secrets/openai_api_key


# ==== LLM提供商配置 ====
LLM_PROVIDER=deepseek
EMBEDDING_PROVIDER=openai
API_BASE_URL=https://api.deepseek.com

# ==== 服务器配置 ====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8501

# ==== CORS安全配置 ====
# ⚠️ 重要：替换为你的实际域名
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 限制HTTP方法
ALLOWED_METHODS=GET,POST,DELETE

# 限制请求头
ALLOWED_HEADERS=Content-Type,Authorization,LLM-API-Key,LLM-Provider,LLM-Base-URL,LLM-Model,Cache-Control,Connection,X-Requested-With

# ==== 安全配置 ====
# ⚠️ 重要：生产环境必须关闭调试模式
DEBUG=False
# 生产环境关闭 FastAPI 自动文档、ReDoc 和 OpenAPI Schema
ENABLE_API_DOCS=False


# ==== 存储配置 ====
UPLOAD_DIR=/app/data/uploads
CHROMA_DB_PATH=/app/data/chroma_db

# ==== 前端配置 ====
BACKEND_URL=http://backend:8000
BACKEND_URL_CLIENT=https://yourdomain.com

# ==== RAG配置 ====
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_SOURCES=3
SIMILARITY_THRESHOLD=0.7

# ==== 成本优化配置 ====
ENABLE_EMBEDDING_CACHE=True
ENABLE_QA_CACHE=True
EMBEDDING_CACHE_TTL_DAYS=7
QA_CACHE_TTL_HOURS=24

# LLM优化
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=800
EMBEDDING_BATCH_SIZE=100
MAX_CONTEXT_LENGTH=4000

# 并发限制
ENABLE_QUOTA_LIMIT=True
MAX_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_LLM_REQUESTS=5

MAX_FILE_SIZE_MB=20