# OpenAI API Configuration
# ⚠️ 不推荐在此文件中设置明文API Key!
# 请使用更安全的方式，参考 SECURITY.md

# 开发测试用 - 请替换为你的密钥
# OPENAI_API_KEY=your_openai_api_key_here

# 推荐的安全配置方式 (选择其中一种):
# OPENAI_API_KEY_FILE=./secrets/openai_api_key/deepseek_api_key
# OPENAI_API_KEY_BASE64=base64_encoded_key_here

# Application Configuration
APP_NAME=RAG Knowledge Base
APP_VERSION=1.0.0
DEBUG=True
# 开发环境如需 Swagger/ReDoc/OpenAPI 文档可设为 True；生产环境必须保持 False
ENABLE_API_DOCS=True


# Storage Configuration
UPLOAD_DIR=./data/uploads
CHROMA_DB_PATH=./data/chroma_db

# API Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=8501

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_SOURCES=3
SIMILARITY_THRESHOLD=0.7